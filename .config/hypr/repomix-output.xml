# screenshot with swappy (another screenshot tool)
bind = $mainMod SHIFT, S, exec, $scriptsDir/ScreenShot.sh --swappy #screenshot (swappy)

# Move windows 
# works also on floating windows and act the same as swap windows when window is not floating
bind = $mainMod CTRL, left, movewindow, l 
bind = $mainMod CTRL, down, movewindow, d
bind = $mainMod CTRL, up, movewindow, u
bind = $mainMod CTRL, right, movewindow, r

bind = $mainMod, j, movefocus, l
bind = $mainMod, k, movefocus, d
bind = $mainMod, l, movefocus, u
bind = $mainMod, p, movefocus, r

# Swap windows
bind = $mainMod ALT, j, swapwindow, l
bind = $mainMod ALT, k, swapwindow, d
bind = $mainMod ALT, l, swapwindow, u
bind = $mainMod ALT, p, swapwindow, r

# Resize windows
binde = $mainMod SHIFT, j, resizeactive,-50 0
binde = $mainMod SHIFT, k, resizeactive,0 -50
binde = $mainMod SHIFT, l, resizeactive,0 50
binde = $mainMod SHIFT, p, resizeactive,50 0

# Move windows
bindd = $mainMod CTRL, j, move window left, movewindow, l
bindd = $mainMod CTRL, p, move window right, movewindow, r
bindd = $mainMod CTRL, l, move window up, movewindow, u
bindd = $mainMod CTRL, k, move window down, movewindow, d

# Workspaces Related

# Skims through all active workspaces that have windows in them
bind = $mainMod, tab, exec, $UserScripts/ActiveWorkspaces.sh next
bind = $mainMod SHIFT, tab, exec, $UserScripts/ActiveWorkspaces.sh prev

# Move/resize windows with mainMod + LMB/RMB and dragging
bindm = $mainMod, mouse:272, movewindow #  mouse:272 = left click
bindm = $mainMod, mouse:273, resizewindow # mouse:272 = right click

# Special workspace
bind = $mainMod SHIFT, U, movetoworkspace, special
bind = $mainMod, U, togglespecialworkspace,

# For single monitor workspaces

# The following mappings use the key codes to better support various keyboard layouts
# Switch workspaces with mainMod + [0-9] 
# bind = $mainMod , code:10, workspace, 1 
# bind = $mainMod , code:11, workspace, 2 
# bind = $mainMod , code:12, workspace, 3 
