local api = vim.api
local M = { terminals = {} }

local function is_valid_buf(buf)
    return buf and api.nvim_buf_is_valid(buf)
end

local function is_valid_win(win)
    return win and api.nvim_win_is_valid(win)
end

local function is_valid_tab(tab)
    return tab and api.nvim_tabpage_is_valid(tab)
end

local function init_terminal(buf, id)
    if api.nvim_buf_line_count(buf) == 1 and api.nvim_buf_get_lines(buf, 0, 1, false)[1] == '' then
        api.nvim_buf_call(buf, function()
            vim.cmd 'terminal'
        end)
    end

    pcall(api.nvim_buf_set_name, buf, '__BufTerm__' .. id)
end

function M._open_window(buf, pos, id)
    local data = M.terminals[id]
    local win

    if pos == 'vsp' then
        vim.cmd 'vsplit'
        win = api.nvim_get_current_win()
        api.nvim_win_set_width(win, math.floor(vim.o.columns * 0.25))
    elseif pos == 'sp' then
        vim.cmd 'split'
        win = api.nvim_get_current_win()
        api.nvim_win_set_height(win, 15)
    elseif pos == 'float' then
        local w = math.floor(vim.o.columns * 0.7)
        local h = math.floor(vim.o.lines * 0.7)
        win = api.nvim_open_win(buf, true, {
            relative = 'editor',
            width = w,
            height = h,
            row = math.floor((vim.o.lines - h) / 2),
            col = math.floor((vim.o.columns - w) / 2),
            style = 'minimal',
            border = 'rounded',
        })
    elseif pos == 'buf' then
        if not is_valid_tab(data.tab) then
            data.prev_tab = data.prev_tab or api.nvim_get_current_tabpage()
            vim.cmd 'tabnew'
            data.tab = api.nvim_get_current_tabpage()
        else
            data.prev_tab = data.prev_tab or api.nvim_get_current_tabpage()
            api.nvim_set_current_tabpage(data.tab)
        end
        win = api.nvim_get_current_win()
    else
        error(("Invalid pos %q; use 'vsp', 'sp', 'float', or 'buf'"):format(pos))
    end

    api.nvim_win_set_buf(win, buf)
    init_terminal(buf, id)
    data.win = win
    vim.cmd 'startinsert'
end

function M.toggle(opts)
    opts = opts or {}

    local pos = opts.pos or 'sp'
    local id = opts.id or 'default'

    M.terminals[id] = M.terminals[id] or {}
    local data = M.terminals[id]

    if not is_valid_buf(data.buf) then
        data.buf = api.nvim_create_buf(false, true)
        api.nvim_set_option_value('buflisted', false, { buf = data.buf })
        api.nvim_set_option_value('bufhidden', 'hide', { buf = data.buf })

        api.nvim_create_autocmd('TermClose', {
            buffer = data.buf,
            once = true,
            callback = function()
                if is_valid_win(data.win) then
                    pcall(api.nvim_win_close, data.win, true)
                end

                if pos == 'buf' and is_valid_tab(data.tab) then
                    pcall(vim.cmd, 'tabclose')
                    if is_valid_tab(data.prev_tab) then
                        pcall(api.nvim_set_current_tabpage, data.prev_tab)
                    end
                end

                data.win = nil
                data.tab = nil
                data.prev_tab = nil
            end,
        })
    end

    if pos == 'buf' then
        if is_valid_tab(data.tab) then
            if api.nvim_get_current_tabpage() == data.tab then
                vim.cmd 'tabclose'
                if is_valid_tab(data.prev_tab) then
                    pcall(api.nvim_set_current_tabpage, data.prev_tab)
                end
                data.win = nil
                data.tab = nil
                data.prev_tab = nil
                return
            end

            data.prev_tab = api.nvim_get_current_tabpage()
            pcall(api.nvim_set_current_tabpage, data.tab)
            return
        end

        data.prev_tab = api.nvim_get_current_tabpage()
        vim.cmd 'tabnew'
        data.tab = api.nvim_get_current_tabpage()
        data.win = api.nvim_get_current_win()
        api.nvim_win_set_buf(data.win, data.buf)
        init_terminal(data.buf, id)
        vim.cmd 'startinsert'
        return
    end

    if is_valid_win(data.win) then
        pcall(api.nvim_win_close, data.win, true)
        data.win = nil
        return
    end

    M._open_window(data.buf, pos, id)
end

return M
